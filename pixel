<script>
// ══════════════════════════════════════════════════════
//  WEB3 CONFIG
// ══════════════════════════════════════════════════════
const GOZO_ADDRESS   = '0xc655797B4FDdE40B4c68CA41C29aadd672d77777';
const BURN_ADDRESS   = '0x000000000000000000000000000000000000dEaD';
const MONAD_CHAIN_ID = '0x279F'; // 10143 = Monad Testnet
const MONAD_CHAIN_ID_DEC = 10143;
const BURN_AMOUNT_WEI = '10000000000000000000'; // 10 * 10^18
const EXPLORER_URL   = 'https://testnet.monadexplorer.com/tx/';

// Minimal ERC20 ABI — only what we need
const ERC20_ABI = [
  // balanceOf
  { name:'balanceOf', type:'function', stateMutability:'view',
    inputs:[{name:'account',type:'address'}],
    outputs:[{name:'',type:'uint256'}] },
  // allowance
  { name:'allowance', type:'function', stateMutability:'view',
    inputs:[{name:'owner',type:'address'},{name:'spender',type:'address'}],
    outputs:[{name:'',type:'uint256'}] },
  // approve
  { name:'approve', type:'function', stateMutability:'nonpayable',
    inputs:[{name:'spender',type:'address'},{name:'amount',type:'uint256'}],
    outputs:[{name:'',type:'bool'}] },
  // transfer (used for burn → send to dead address)
  { name:'transfer', type:'function', stateMutability:'nonpayable',
    inputs:[{name:'to',type:'address'},{name:'amount',type:'uint256'}],
    outputs:[{name:'',type:'bool'}] },
];

// ── ABI encode helpers (no ethers dependency) ──────────
function hexPad(hex, bytes=32) {
  return hex.replace('0x','').padStart(bytes*2,'0');
}
function encodeCall(sig, ...params) {
  // keccak4 selector from signature string
  const selector = keccak4(sig);
  return '0x' + selector + params.join('');
}

// Tiny keccak256 selector (first 4 bytes) using browser's SubtleCrypto
// We pre-compute them since SubtleCrypto is async and we need sync calls
// selectors pre-computed:
const SEL = {
  balanceOf : 'balanceOf(address)',          // 0x70a08231
  allowance : 'allowance(address,address)',  // 0xdd62ed3e
  approve   : 'approve(address,uint256)',    // 0x095ea7b3
  transfer  : 'transfer(address,uint256)',   // 0xa9059cbb
};

// We'll use eth_call with raw hex encoding
function abiEncodeAddr(addr) {
  return hexPad(addr.toLowerCase().replace('0x',''), 32);
}
function abiEncodeUint(val) {
  // val is a BigInt or string
  return BigInt(val).toString(16).padStart(64,'0');
}

// Function selectors (keccak256 first 4 bytes) — pre-computed
const FN = {
  balanceOf : '70a08231',
  allowance : 'dd62ed3e',
  approve   : '095ea7b3',
  transfer  : 'a9059cbb',
};

// ── State ──────────────────────────────────────────────
let walletAddr = null;
let provider   = null; // window.ethereum
let flowStep   = 0; // 0=idle, 1=connected, 2=approved, 3=burned
let burning    = false;

// ── UI helpers ─────────────────────────────────────────
function setStatus(msg, type='') {
  const el = document.getElementById('statusMsg');
  el.textContent = msg;
  el.className = 'status-msg' + (type ? ' '+type : '');
}
function setStep(n, state) { // state: active|done|error|''
  const el = document.getElementById('step'+n);
  el.className = 'step ' + state;
  const icons = { active:'⟳', done:'✓', error:'✗', '':'○' };
  document.getElementById('s'+n+'icon').textContent = icons[state] || '○';
  if (state === 'active') document.getElementById('s'+n+'icon').classList.add('spin');
  else document.getElementById('s'+n+'icon').classList.remove('spin');
}
function setProgress(pct) {
  document.getElementById('progressBar').classList.add('show');
  document.getElementById('progressFill').style.width = pct + '%';
}
function showTx(hash) {
  const el = document.getElementById('txLink');
  el.href = EXPLORER_URL + hash;
  el.classList.add('show');
}
function setBtn(text, disabled=false) {
  const b = document.getElementById('mainBtn');
  b.textContent = text;
  b.disabled = disabled;
}
function showRetry(show) {
  document.getElementById('retryBtn').style.display = show ? 'block' : 'none';
}

// ── Particles canvas ───────────────────────────────────
(function initParticles() {
  const pc = document.getElementById('particles');
  const px = pc.getContext('2d');
  pc.width  = window.innerWidth;
  pc.height = window.innerHeight;
  const pts = Array.from({length:60}, () => ({
    x: Math.random()*pc.width,
    y: Math.random()*pc.height,
    r: Math.random()*1.5 + 0.3,
    vy: -(Math.random()*0.3 + 0.1),
    a: Math.random(),
  }));
  function drawParticles() {
    px.clearRect(0,0,pc.width,pc.height);
    pts.forEach(p => {
      p.y += p.vy;
      p.a += 0.005;
      if (p.y < 0) { p.y = pc.height; p.x = Math.random()*pc.width; }
      px.fillStyle = `rgba(245,197,66,${Math.sin(p.a)*0.3+0.1})`;
      px.beginPath();
      px.arc(p.x, p.y, p.r, 0, Math.PI*2);
      px.fill();
    });
    requestAnimationFrame(drawParticles);
  }
  drawParticles();
})();

// ── Preview character on gate ──────────────────────────
(function drawPreview() {
  const pc = document.getElementById('previewCanvas');
  const px = pc.getContext('2d');
  px.imageSmoothingEnabled = false;
  const S2 = 6;
