      ctx.fillRect(tx,GROUND_Y-th,18,th);
      ctx.fillStyle='#122a12';
      ctx.fillRect(tx-5,GROUND_Y-th-10,28,16);
      ctx.fillRect(tx-1,GROUND_Y-th-22,20,13);
      ctx.fillRect(tx+3,GROUND_Y-th-32,12,12);
    }

    // GOZO badge in sky
    ctx.fillStyle='rgba(245,197,66,0.12)';
    ctx.font='bold 9px "Courier New"';
    ctx.fillText('$GOZO', 8, 240);
  }

  function drawPlatforms(){
    for(const p of platforms){
      ctx.fillStyle='#4a2810'; ctx.fillRect(p.x,p.y+4,p.w,p.h-4);
      for(let gx=p.x;gx<p.x+p.w;gx+=3){
        ctx.fillStyle='#5a7a32'; ctx.fillRect(gx,p.y,3,3+(gx*13%3));
      }
      ctx.fillStyle='#7aaf44'; ctx.fillRect(p.x,p.y,p.w,3);
      ctx.fillStyle='#2a1508'; ctx.fillRect(p.x,p.y+p.h-2,p.w,2);
    }
  }

  function update(){
    gameTick++;
    player.vx=0;
    if(keys['ArrowLeft']||keys['KeyA']){player.vx=-SPEED;player.facing=-1;}
    if(keys['ArrowRight']||keys['KeyD']){player.vx=SPEED;player.facing=1;}
    if((keys['Space']||keys['ArrowUp']||keys['KeyW'])&&player.grounded){
      player.vy=JUMP_V; player.grounded=false;
    }
    if(keys['KeyZ']&&player.attackTick<=0) player.attackTick=18;

    player.vy+=GRAVITY;
    player.x+=player.vx; player.y+=player.vy;
    player.grounded=false;

    for(const p of platforms){
      const prevB=player.y+CH-player.vy;
      if(player.x+CW>p.x && player.x<p.x+p.w &&
         player.y+CH>=p.y && prevB<=p.y+2 && player.vy>=0){
        player.y=p.y-CH; player.vy=0; player.grounded=true;
      }
    }
    player.x=Math.max(0,Math.min(512-CW,player.x));
    if(player.y>320){lives=Math.max(0,lives-1);player.x=60;player.y=GROUND_Y-CH;player.vy=0;updateHUD();}

    if(player.attackTick>0){player.attackTick--;player.state='attack';}
    else if(!player.grounded){player.state='jump';}
    else if(player.vx!==0){player.state='walk';}
    else{player.state='idle';}

    player.frameTick++;
    if(player.frameTick>9){player.frameTick=0;player.frame=1-player.frame;}

    const pcx=player.x+CW/2, pcy=player.y+CH/2;
    for(const coin of coins){
      if(!coin.collected && Math.abs(pcx-coin.x)<14 && Math.abs(pcy-coin.y)<14){
        coin.collected=true; score+=10; updateHUD();
      }
    }
    if(coins.every(c=>c.collected)) spawnCoins();

    for(const e of enemies){
      if(!e.alive) continue;
      e.x+=e.vx;
      if(e.x<0||e.x>480) e.vx*=-1;
      for(const p of platforms){
        if(e.plat!==undefined&&(e.x<p.x||e.x+CW>p.x+p.w)) e.vx*=-1;
      }
      e.tick++; if(e.tick>8){e.tick=0;e.frame=1-e.frame;}
      if(player.vy>0 && collideRect(player.x,player.y,CW,CH,e.x,e.y,CW,CH) && player.y+CH<e.y+CH/2){
        e.alive=false; player.vy=JUMP_V*0.6; score+=50; updateHUD();
      } else if(collideRect(player.x+4,player.y+4,CW-8,CH-8,e.x+4,e.y+4,CW-8,CH-8)){
        if(player.attackTick>0){e.alive=false;score+=50;updateHUD();}
        else if(gameTick%60===0){lives=Math.max(0,lives-1);updateHUD();}
      }
    }
  }

  function render(){
    drawBG(); drawPlatforms();
    const t=gameTick*0.06;
    for(const coin of coins) if(!coin.collected) drawCoin(coin.x,coin.y,t+coin.t);
    for(const e of enemies){
      if(!e.alive) continue;
      drawSlime(e.frame===0?SLIME_A:SLIME_B, e.x, e.y+(CH-9*S));
    }
    ctx.fillStyle='#00000030';
    ctx.beginPath(); ctx.ellipse(player.x+CW/2,GROUND_Y+3,14,4,0,0,Math.PI*2); ctx.fill();

    let sprite;
    if(player.state==='jump') sprite=JUMP;
    else if(player.state==='walk') sprite=player.frame===0?WALK_A:WALK_B;
    else sprite=IDLE;
    drawSprite(sprite, Math.round(player.x), Math.round(player.y), player.facing===-1);

    if(player.attackTick>0){
      const flip=player.facing===-1;
      const ax=flip?player.x-18:player.x+CW+2;
      const alpha=player.attackTick/18;
      ctx.fillStyle=`rgba(255,220,50,${alpha*0.8})`;
      ctx.fillRect(ax, player.y+20, 16, 6);
    }

    // HUD
    ctx.fillStyle='#00000099'; ctx.fillRect(0,0,512,22);
    ctx.fillStyle='#F5C542'; ctx.font='bold 10px "Courier New"';
    ctx.fillText(`SCORE:${score}`,8,14);
    ctx.fillStyle='#ff6666';
    ctx.fillText('♥'.repeat(lives)+'♡'.repeat(Math.max(0,3-lives)),220,14);
    // GOZO tag
    ctx.fillStyle='#F5C542aa'; ctx.font='7px "Courier New"';
    ctx.fillText('🔥$GOZO',420,14);
  }

  function gameLoop(){update();render();requestAnimationFrame(gameLoop);}
  updateHUD();
  requestAnimationFrame(gameLoop);
}
</script>
</body>
</html>
