<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pixel Homie — Powered by $GOZO</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

  :root {
    --gold: #F5C542;
    --gold2: #FFE066;
    --dark: #0a0c10;
    --panel: #12161e;
    --border: #2a2f3a;
    --red: #ff4444;
    --green: #44ff88;
    --blue: #1A8FFF;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--dark);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: 'Press Start 2P', 'Courier New', monospace;
    color: #fff;
    overflow: hidden;
  }

  /* ── PARTICLES BG ── */
  #particles { position: fixed; inset: 0; pointer-events: none; z-index: 0; }

  /* ── SCREENS ── */
  .screen {
    position: relative;
    z-index: 10;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 100vh;
    padding: 20px;
  }
  .screen.active { display: flex; }

  /* ── GATE SCREEN ── */
  #gate {
    gap: 0;
  }

  .gate-logo {
    font-size: 0.55rem;
    color: var(--gold);
    letter-spacing: 3px;
    text-shadow: 0 0 20px var(--gold);
    margin-bottom: 4px;
    animation: pulse 2s ease-in-out infinite;
  }
  .gate-title {
    font-size: 1.4rem;
    color: #fff;
    text-shadow: 0 0 30px var(--gold);
    margin-bottom: 6px;
  }
  .gate-sub {
    font-size: 0.4rem;
    color: #888;
    letter-spacing: 2px;
    margin-bottom: 28px;
  }

  /* Character preview on gate */
  #previewCanvas {
    image-rendering: pixelated;
    margin-bottom: 24px;
    filter: drop-shadow(0 0 16px #F5C54266);
  }

  .gate-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 20px 28px;
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .gate-panel-title {
    font-size: 0.45rem;
    color: var(--gold);
    letter-spacing: 2px;
    text-align: center;
    border-bottom: 1px solid var(--border);
    padding-bottom: 12px;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.35rem;
    letter-spacing: 1px;
  }
  .info-row .label { color: #666; }
  .info-row .val   { color: #ccc; }
  .info-row .val.highlight { color: var(--gold); }

  .wallet-address {
    font-size: 0.3rem;
    color: #555;
    text-align: center;
    word-break: break-all;
    padding: 8px;
    background: #0a0c10;
    border: 1px solid #1a1f2a;
    border-radius: 1px;
    display: none;
  }
  .wallet-address.show { display: block; }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .step {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.32rem;
    color: #555;
    letter-spacing: 1px;
    padding: 8px 10px;
    border: 1px solid #1a1f2a;
    border-radius: 1px;
    transition: all 0.3s;
  }
  .step.active   { color: var(--gold); border-color: #3a3010; background: #1a1500; }
  .step.done     { color: var(--green); border-color: #0a2a1a; background: #051208; }
  .step.error    { color: var(--red);  border-color: #2a0a0a; background: #120505; }
  .step-icon     { font-size: 0.6rem; min-width: 18px; text-align: center; }
  .step-text     { flex: 1; }
  .step-status   { font-size: 0.55rem; }

  /* Buttons */
  .btn {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.45rem;
    letter-spacing: 2px;
    padding: 14px 20px;
    border: none;
    cursor: pointer;
    width: 100%;
    position: relative;
    overflow: hidden;
    transition: all 0.15s;
    border-radius: 1px;
  }
  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.08);
    opacity: 0;
    transition: opacity 0.15s;
  }
  .btn:hover::after { opacity: 1; }
  .btn:active { transform: translateY(1px); }

  .btn-primary {
    background: var(--gold);
    color: #000;
    box-shadow: 0 4px 0 #8B7000, 0 0 20px #F5C54244;
  }
  .btn-primary:hover { box-shadow: 0 4px 0 #8B7000, 0 0 30px #F5C54266; }
  .btn-primary:disabled { background: #333; color: #555; box-shadow: none; cursor: not-allowed; }

  .btn-secondary {
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold);
  }

  .btn-danger {
    background: #8B0000;
    color: #fff;
    box-shadow: 0 4px 0 #3a0000, 0 0 20px #ff000022;
  }

  /* TX link */
  .tx-link {
    font-size: 0.28rem;
    color: #555;
    text-align: center;
    text-decoration: none;
    letter-spacing: 1px;
    display: none;
    word-break: break-all;
  }
  .tx-link.show { display: block; color: var(--blue); }
  .tx-link:hover { color: var(--gold2); }

  /* Status message */
  .status-msg {
    font-size: 0.32rem;
    text-align: center;
    min-height: 16px;
    color: #666;
    letter-spacing: 1px;
    animation: blink 1s step-end infinite;
  }
  .status-msg.ok  { color: var(--green); animation: none; }
  .status-msg.err { color: var(--red);   animation: none; }

  /* ── GAME SCREEN ── */
  #game { gap: 0; padding: 0; justify-content: flex-start; background: #080b10; }

  /* Top header bar */
  .game-topbar {
    width: 100%;
    max-width: 512px;
    background: linear-gradient(90deg, #0a0d14 0%, #12161e 50%, #0a0d14 100%);
    border-bottom: 2px solid #F5C54233;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }
  .game-topbar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.12) 2px,rgba(0,0,0,0.12) 4px);
    pointer-events: none;
  }
  .game-topbar::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
    opacity: 0.4;
  }

  /* Left: wallet info */
  .hdr-left { display: flex; flex-direction: column; gap: 5px; z-index: 1; min-width: 130px; }
  .hdr-wallet { display: flex; align-items: center; gap: 6px; }
  .hdr-wallet-dot { width: 5px; height: 5px; background: #44ff88; border-radius: 50%; box-shadow: 0 0 5px #44ff88; flex-shrink:0; animation: pulse 2s ease infinite; }
  .hdr-wallet-addr { font-size: 0.26rem; color: #666; letter-spacing: 1px; }
  .hdr-gozo-bal { display: flex; align-items: center; gap: 5px; font-size: 0.24rem; color: #444; letter-spacing: 1px; }
  .hdr-gozo-bal .fire { font-size: 0.35rem; }
  .hdr-gozo-bal .amt { color: var(--gold); font-size: 0.3rem; }
  .hdr-monad { display: flex; align-items: center; gap: 4px; font-size: 0.21rem; color: #5c3; letter-spacing: 1px; margin-top: 1px; }
  .hdr-monad-dot { width: 4px; height: 4px; background: #5c3; border-radius: 50%; box-shadow: 0 0 4px #5c3; animation: pulse 1.5s ease infinite; }

  /* Center: logo */
  .hdr-center {
    position: absolute;
    left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    z-index: 1;
    pointer-events: none;
  }
  .hdr-logo {
    font-size: 0.6rem;
    color: var(--gold);
    text-shadow: 0 0 16px #F5C54299, 0 0 32px #F5C54244;
    letter-spacing: 4px;
    line-height: 1;
    white-space: nowrap;
  }
  .hdr-tagline {
    font-size: 0.2rem;
    color: #F5C54244;
    letter-spacing: 3px;
    white-space: nowrap;
  }

  /* Right: score + lives */
  .hdr-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; z-index: 1; min-width: 130px; }
  .hdr-score-label { font-size: 0.22rem; color: #444; letter-spacing: 2px; }
  .hdr-score-val { font-size: 0.5rem; color: var(--gold); text-shadow: 0 0 10px #F5C54266; letter-spacing: 2px; line-height: 1; }
  .hdr-lives { display: flex; gap: 3px; align-items: center; }
  .heart-on  { color: #ff4466; font-size: 0.55rem; line-height: 1; text-shadow: 0 0 8px #ff446699; }
  .heart-off { color: #2a2030; font-size: 0.55rem; line-height: 1; }

  /* Canvas */
  canvas#c {
    border-left: 2px solid #1a1f2a;
    border-right: 2px solid #1a1f2a;
    border-bottom: none;
    box-shadow: 0 8px 40px #000c, 0 0 60px #F5C54211;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    display: block;
    width: 512px;
    max-width: 100%;
  }

  /* Footer */
  .game-footer {
    width: 512px;
    max-width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.24rem;
    color: #2a2f3a;
    letter-spacing: 1px;
    padding: 7px 16px;
    background: #0a0c10;
    border: 2px solid #1a1f2a;
    border-top: 1px solid #1a1f2a;
    box-sizing: border-box;
  }
  .game-footer kbd {
    color: #F5C54277;
    background: #12161e;
    padding: 2px 5px;
    border-radius: 1px;
    font-family: inherit;
    font-size: 0.22rem;
    border: 1px solid #2a2f3a;
  }
  .footer-contract { font-size: 0.2rem; color: #1e2230; }

  /* ── ANIMATIONS ── */
  @keyframes pulse {
    0%,100% { opacity: 1; }
    50%      { opacity: 0.6; }
  }
  @keyframes blink {
    0%,100% { opacity: 1; }
    50%      { opacity: 0; }
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes burnFloat {
    0%   { transform: translateY(0) scale(1);  opacity: 1; }
    100% { transform: translateY(-60px) scale(0.5); opacity: 0; }
  }

  .spin { animation: spin 1s linear infinite; display: inline-block; }
  .fade-in { animation: fadeIn 0.4s ease forwards; }

  /* Floating burn notification */
  .burn-notify {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Press Start 2P', monospace;
    font-size: 0.7rem;
    color: var(--gold);
    text-shadow: 0 0 20px var(--gold);
    z-index: 999;
    pointer-events: none;
    animation: burnFloat 2s ease forwards;
    white-space: nowrap;
  }

  /* Network badge */
  .net-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.28rem;
    color: #6c3;
    letter-spacing: 1px;
  }
  .net-dot {
    width: 6px; height: 6px;
    background: #6c3;
    border-radius: 50%;
    box-shadow: 0 0 6px #6c3;
    animation: pulse 1.5s ease infinite;
  }
  .net-badge.wrong { color: var(--red); }
  .net-badge.wrong .net-dot { background: var(--red); box-shadow: 0 0 6px var(--red); }

  /* Progress bar for burn */
  .progress-bar {
    width: 100%;
    height: 4px;
    background: #1a1f2a;
    border-radius: 2px;
    overflow: hidden;
    display: none;
  }
  .progress-bar.show { display: block; }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold2));
    width: 0%;
    transition: width 0.3s ease;
    box-shadow: 0 0 8px var(--gold);
  }
</style>
</head>
<body>

<canvas id="particles"></canvas>

