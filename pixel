async function handleMainBtn() {
  if (!walletAddr)       return connectWallet();
  if (flowStep === 1)    return doApprove();
  if (flowStep === 2)    return doBurn();
}

async function connectWallet() {
  const eth = window.ethereum;
  if (!eth) {
    setStatus('⚠ NO WALLET DETECTED. INSTALL METAMASK OR RABBY.', 'err');
    return;
  }
  setBtn('CONNECTING...', true);
  setStep(1,'active');
  setStatus('REQUESTING WALLET ACCESS...');
  try {
    const accounts = await eth.request({ method: 'eth_requestAccounts' });
    walletAddr = accounts[0];
    provider = eth;

    // Show address
    const shortAddr = walletAddr.slice(0,6)+'…'+walletAddr.slice(-4);
    document.getElementById('walletAddr').textContent = walletAddr;
    document.getElementById('walletAddr').classList.add('show');
    document.getElementById('gameWalletBadge').textContent = shortAddr;

    setStep(1,'done');
    setStatus('WALLET CONNECTED!', 'ok');

    // Check/switch network
    await ensureMonadNetwork();

    // Fetch balance
    await updateBalance();

    flowStep = 1;
    setBtn('APPROVE 10 GOZO →');
    setStep(2,'');

  } catch(e) {
    setStep(1,'error');
    setStatus('CONNECTION REJECTED.', 'err');
    setBtn('CONNECT WALLET', false);
    console.error(e);
  }
}

async function ensureMonadNetwork() {
  const chainId = await provider.request({ method: 'eth_chainId' });
  if (chainId.toLowerCase() !== MONAD_CHAIN_ID.toLowerCase()) {
    setStatus('SWITCHING TO MONAD NETWORK...');
    try {
      await provider.request({
        method: 'wallet_switchEthereumChain',
        params: [{ chainId: MONAD_CHAIN_ID }],
      });
    } catch(switchErr) {
      if (switchErr.code === 4902) {
        // Add network
        await provider.request({
          method: 'wallet_addEthereumChain',
          params: [{
            chainId: MONAD_CHAIN_ID,
            chainName: 'Monad Testnet',
            nativeCurrency: { name: 'MON', symbol: 'MON', decimals: 18 },
            rpcUrls: ['https://testnet-rpc.monad.xyz'],
            blockExplorerUrls: ['https://testnet.monadexplorer.com'],
          }],
        });
      } else throw switchErr;
    }
  }
  document.getElementById('netBadge').className = 'net-badge';
  document.getElementById('netName').textContent = 'MONAD';
}

async function updateBalance() {
  try {
    const data = '0x' + FN.balanceOf + abiEncodeAddr(walletAddr);
    const res = await provider.request({
      method: 'eth_call',
      params: [{ to: GOZO_ADDRESS, data }, 'latest'],
    });
    const bal = BigInt(res);
    const formatted = (Number(bal) / 1e18).toFixed(2);
    document.getElementById('balanceVal').textContent = formatted + ' GOZO';
    document.getElementById('balanceVal').className = 'val highlight';
    return bal;
  } catch(e) {
    document.getElementById('balanceVal').textContent = 'ERROR';
    return 0n;
  }
}

async function doApprove() {
  setBtn('APPROVING...', true);
  setStep(2,'active');
  setStatus('WAITING FOR APPROVAL SIGNATURE...');
  setProgress(10);
  showRetry(false);
  try {
    // Encode approve(BURN_ADDRESS, BURN_AMOUNT)
    const data = '0x' + FN.approve
      + abiEncodeAddr(BURN_ADDRESS)
      + abiEncodeUint(BURN_AMOUNT_WEI);

    const txHash = await provider.request({
      method: 'eth_sendTransaction',
      params: [{
        from: walletAddr,
        to: GOZO_ADDRESS,
        data,
      }],
    });

    setStatus('APPROVE TX SENT — WAITING CONFIRMATION...');
    setProgress(40);
    showTx(txHash);

    await waitForTx(txHash);

    setStep(2,'done');
    setProgress(60);
    setStatus('APPROVED! NOW BURN THE GOZO 🔥', 'ok');
    flowStep = 2;
    setBtn('🔥 BURN 10 GOZO & PLAY!');
    setStep(3,'');

  } catch(e) {
    setStep(2,'error');
    const msg = e.code === 4001 ? 'APPROVAL REJECTED BY USER.' : 'APPROVAL FAILED: ' + (e.message||'').slice(0,40);
    setStatus(msg, 'err');
    setBtn('APPROVE 10 GOZO →', false);
    showRetry(true);
    console.error(e);
  }
}

async function retryApprove() {
  showRetry(false);
  setStep(2,'');
  if (flowStep === 1) doApprove();
  else if (flowStep === 2) doBurn();
}

async function doBurn() {
  if (burning) return;
  burning = true;
  setBtn('BURNING...', true);
  setStep(3,'active');
  setStatus('CONFIRM BURN TRANSACTION IN WALLET...');
  setProgress(65);
  showRetry(false);

  // Check balance first
  const bal = await updateBalance();
  if (bal < BigInt(BURN_AMOUNT_WEI)) {
    setStep(3,'error');
    setStatus('INSUFFICIENT GOZO BALANCE!', 'err');
    setBtn('🔥 BURN 10 GOZO & PLAY!', false);
    burning = false;
    showRetry(false);
    return;
  }

  try {
    // Burn = transfer to dead address
    const data = '0x' + FN.transfer
      + abiEncodeAddr(BURN_ADDRESS)
      + abiEncodeUint(BURN_AMOUNT_WEI);

    const txHash = await provider.request({
      method: 'eth_sendTransaction',
      params: [{
        from: walletAddr,
        to: GOZO_ADDRESS,
        data,
      }],
    });

    setStatus('BURN TX SENT — WAITING CONFIRMATION...');
    setProgress(80);
    showTx(txHash);

    await waitForTx(txHash);

    setStep(3,'done');
    setProgress(100);
    setStatus('🔥 10 GOZO BURNED! LAUNCHING GAME...', 'ok');

    // Show burn notification
    const notify = document.createElement('div');
    notify.className = 'burn-notify';
    notify.textContent = '🔥 -10 $GOZO 🔥';
    document.body.appendChild(notify);
    setTimeout(() => notify.remove(), 2000);

    await sleep(1500);
    launchGame();

  } catch(e) {
    burning = false;
    setStep(3,'error');
    const msg = e.code === 4001 ? 'BURN REJECTED BY USER.' : 'BURN FAILED: '+(e.message||'').slice(0,40);
    setStatus(msg, 'err');
    setBtn('🔥 BURN 10 GOZO & PLAY!', false);
    showRetry(true);
    console.error(e);
  }
}

// Poll for tx receipt
async function waitForTx(hash, maxAttempts=60, interval=2000) {
  for (let i = 0; i < maxAttempts; i++) {
    await sleep(interval);
    try {
      const receipt = await provider.request({
        method: 'eth_getTransactionReceipt',
        params: [hash],
      });
      if (receipt && receipt.status) {
        if (receipt.status === '0x1') return receipt;
        if (receipt.status === '0x0') throw new Error('Transaction reverted');
      }
    } catch(e) { if (e.message !== 'Transaction reverted') continue; else throw e; }
  }
  throw new Error('TX timeout');
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

